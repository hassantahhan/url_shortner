{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "Global URL shortener using Cloudflare Workers and KV",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
