    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "typescript-eslint": "^8.57.2",
    "eslint": "^9.21.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "wrangler": "latest"
  }
}
