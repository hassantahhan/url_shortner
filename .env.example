# Environment variables for URL Shortener

# API Key for protected operations (e.g., DELETE)
API_KEY=sk_prod_your_secret_key_here

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Custom domain for shortened URLs (optional, overrides wrangler.toml)
CUSTOM_DOMAIN=short.example.com

# Rate limit settings (optional, customize as needed)
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Enable analytics collection
ENABLE_ANALYTICS=true

# Debug mode (verbose logging)
DEBUG=false
